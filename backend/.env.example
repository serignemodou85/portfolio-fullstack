# Django core
DEBUG=true
SERVE_MEDIA_LOCALLY=true
SERVE_STATIC_LOCALLY=true
SECRET_KEY=change_me_with_a_long_random_secret
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=portfolio_db
DB_USER=root
DB_PASSWORD=change_me
DB_HOST=127.0.0.1
DB_PORT=3307
# Optional in production (Render/Heroku): overrides DB_* when set
DATABASE_URL=

# CORS / CSRF
FRONTEND_URL=http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CSRF_TRUSTED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# API throttling (increase in local dev if you hit HTTP 429)
API_THROTTLE_ANON_RATE=2000/hour
API_THROTTLE_USER_RATE=5000/hour
API_THROTTLE_AUTH_LOGIN_RATE=20/minute
API_THROTTLE_PASSWORD_RESET_REQUEST_RATE=10/hour
API_THROTTLE_PASSWORD_RESET_CONFIRM_RATE=20/hour
API_THROTTLE_CONTACT_CREATE_RATE=60/hour

# Transport security (set strict values in production)
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false
SECURE_HSTS_PRELOAD=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
X_FRAME_OPTIONS=DENY
SECURE_REFERRER_POLICY=same-origin
SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURE_CROSS_ORIGIN_RESOURCE_POLICY=same-site
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SAMESITE=Lax

# JWT
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Upload limits (bytes)
DATA_UPLOAD_MAX_MEMORY_SIZE=5242880
FILE_UPLOAD_MAX_MEMORY_SIZE=5242880
MAX_IMAGE_UPLOAD_SIZE=5242880
MAX_FILE_UPLOAD_SIZE=10485760

# Gmail SMTP configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false

# Use Gmail address + App Password (not your normal account password)
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password
DEFAULT_FROM_EMAIL=your@gmail.com

# One or many recipients separated by comma
CONTACT_ADMIN_EMAILS=your@gmail.com

# Auto acknowledgement to client after contact form submit
CONTACT_AUTO_REPLY_ENABLED=true

# Cloudinary (media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
