{
  "buildCommand": "npx ng build --configuration production",
  "outputDirectory": "dist/frontend/browser",
  "rewrites": [
    {
      "source": "/((?!.*\\.[a-z0-9]+$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
